generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AssetType {
  gold
  silver
  crypto
  us_stock
  egx_stock
}

enum WeightUnit {
  grams
  ounces
}

enum ValuationMode {
  live
  manual
}

model Investment {
  id               Int        @id @default(autoincrement())
  name             String     @db.VarChar(200)
  symbol           String     @db.VarChar(50)
  assetType        AssetType  @map("asset_type")
  quantity         Float
  purchasePrice    Float      @map("purchase_price")
  purchaseCurrency String     @default("USD") @map("purchase_currency") @db.VarChar(10)
  purchaseDate     DateTime?  @map("purchase_date")
  weightUnit       WeightUnit? @map("weight_unit")
  valuationMode    ValuationMode @default(live) @map("valuation_mode")
  currentValue     Float?     @map("current_value")
  notes            String?    @db.VarChar(500)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([assetType])
  @@map("investments")
}

model PriceAlert {
  id          Int       @id @default(autoincrement())
  symbol      String    @db.VarChar(50)
  assetType   AssetType @map("asset_type")
  targetPrice Float     @map("target_price")
  condition   String    @db.VarChar(10)
  currency    String    @default("USD") @db.VarChar(10)
  isTriggered Boolean   @default(false) @map("is_triggered")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([isActive, isTriggered])
  @@map("price_alerts")
}

model PortfolioSnapshot {
  id            Int      @id @default(autoincrement())
  totalValueUsd Float    @map("total_value_usd")
  totalValueEgp Float    @map("total_value_egp")
  snapshotDate  DateTime @default(now()) @map("snapshot_date")

  @@index([snapshotDate])
  @@map("portfolio_snapshots")
}
